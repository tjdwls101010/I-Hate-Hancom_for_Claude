<?xml version='1.0' encoding='UTF-8'?>
<!--
  sample_section0.xml — 주석 달린 section0.xml 예제

  section0.xml은 HWPX 문서의 본문 내용을 담는 파일이다.
  네임스페이스: hp(paragraph), hs(section)

  핵심 규칙:
  - 첫 문단의 첫 run에 반드시 secPr(페이지설정) + colPr(단설정) 포함
  - 문단 id는 고유 숫자 (1000000001부터 순차 권장)
  - paraPrIDRef: header.xml의 paraPr id 참조 (0=기본, 20=가운데 등)
  - charPrIDRef: header.xml의 charPr id 참조 (0=기본 10pt, 7=제목 등)
  - 빈 줄: <hp:t/> (빈 텍스트 런)
-->
<hs:sec xmlns:hp="http://www.hancom.co.kr/hwpml/2011/paragraph"
        xmlns:hs="http://www.hancom.co.kr/hwpml/2011/section">

  <!-- ============================================================
       첫 문단: secPr(섹션속성) + colPr(단속성) — 필수!
       이 문단이 페이지 크기, 여백 등을 정의한다.
       ============================================================ -->
  <hp:p id="1000000001" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <hp:run charPrIDRef="0">
      <!-- secPr: 섹션 속성 (페이지 크기, 여백 등) -->
      <hp:secPr id="" textDirection="HORIZONTAL" spaceColumns="1134" tabStop="8000"
                tabStopVal="4000" tabStopUnit="HWPUNIT" outlineShapeIDRef="1"
                memoShapeIDRef="0" textVerticalWidthHead="0" masterPageCnt="0">
        <hp:grid lineGrid="0" charGrid="0" wonggojiFormat="0"/>
        <hp:startNum pageStartsOn="BOTH" page="0" pic="0" tbl="0" equation="0"/>
        <hp:visibility hideFirstHeader="0" hideFirstFooter="0" hideFirstMasterPage="0"
                      border="SHOW_ALL" fill="SHOW_ALL" hideFirstPageNum="0"
                      hideFirstEmptyLine="0" showLineNumber="0"/>
        <hp:lineNumberShape restartType="0" countBy="0" distance="0" startNumber="0"/>
        <!--
          pagePr: 용지 크기 (HWPUNIT = 1/7200 인치)
          A4: width=59528 height=84186
          margin: 좌우 8504(30mm), 상 5668(20mm), 하 4252(15mm)
          본문 가용폭 = 59528 - 8504*2 = 42520
        -->
        <hp:pagePr landscape="WIDELY" width="59528" height="84186" gutterType="LEFT_ONLY">
          <hp:margin header="4252" footer="4252" gutter="0"
                    left="8504" right="8504" top="5668" bottom="4252"/>
        </hp:pagePr>
        <hp:footNotePr>
          <hp:autoNumFormat type="DIGIT" userChar="" prefixChar="" suffixChar=")" supscript="0"/>
          <hp:noteLine length="-1" type="SOLID" width="0.12 mm" color="#000000"/>
          <hp:noteSpacing betweenNotes="283" belowLine="567" aboveLine="850"/>
          <hp:numbering type="CONTINUOUS" newNum="1"/>
          <hp:placement place="EACH_COLUMN" beneathText="0"/>
        </hp:footNotePr>
        <hp:endNotePr>
          <hp:autoNumFormat type="DIGIT" userChar="" prefixChar="" suffixChar=")" supscript="0"/>
          <hp:noteLine length="14692344" type="SOLID" width="0.12 mm" color="#000000"/>
          <hp:noteSpacing betweenNotes="0" belowLine="567" aboveLine="850"/>
          <hp:numbering type="CONTINUOUS" newNum="1"/>
          <hp:placement place="END_OF_DOCUMENT" beneathText="0"/>
        </hp:endNotePr>
        <hp:pageBorderFill type="BOTH" borderFillIDRef="1" textBorder="PAPER"
                          headerInside="0" footerInside="0" fillArea="PAPER">
          <hp:offset left="1417" right="1417" top="1417" bottom="1417"/>
        </hp:pageBorderFill>
        <hp:pageBorderFill type="EVEN" borderFillIDRef="1" textBorder="PAPER"
                          headerInside="0" footerInside="0" fillArea="PAPER">
          <hp:offset left="1417" right="1417" top="1417" bottom="1417"/>
        </hp:pageBorderFill>
        <hp:pageBorderFill type="ODD" borderFillIDRef="1" textBorder="PAPER"
                          headerInside="0" footerInside="0" fillArea="PAPER">
          <hp:offset left="1417" right="1417" top="1417" bottom="1417"/>
        </hp:pageBorderFill>
      </hp:secPr>
      <!-- colPr: 단(column) 속성 — 1단 기본 -->
      <hp:ctrl>
        <hp:colPr id="" type="NEWSPAPER" layout="LEFT" colCount="1" sameSz="1" sameGap="0"/>
      </hp:ctrl>
    </hp:run>
    <!-- 첫 문단의 두 번째 run: 빈 텍스트 (secPr 문단은 보통 내용 없음) -->
    <hp:run charPrIDRef="0">
      <hp:t/>
    </hp:run>
  </hp:p>

  <!-- ============================================================
       일반 문단: 텍스트만 포함
       paraPrIDRef="0" → 기본 양쪽정렬, 160% 줄간격
       charPrIDRef="0" → 기본 10pt 함초롬바탕
       ============================================================ -->
  <hp:p id="1000000002" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <hp:run charPrIDRef="0">
      <hp:t>일반 본문 텍스트입니다.</hp:t>
    </hp:run>
  </hp:p>

  <!-- ============================================================
       빈 줄: <hp:t/> 사용 (닫힌 태그)
       ============================================================ -->
  <hp:p id="1000000003" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <hp:run charPrIDRef="0">
      <hp:t/>
    </hp:run>
  </hp:p>

  <!-- ============================================================
       서식 혼합 런: 한 문단에 여러 run
       각 run은 다른 charPrIDRef를 가질 수 있다.
       ============================================================ -->
  <hp:p id="1000000004" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <!-- 일반 텍스트 -->
    <hp:run charPrIDRef="0">
      <hp:t>일반 텍스트와 </hp:t>
    </hp:run>
    <!-- 볼드 텍스트 (charPr 7 등 bold 정의된 ID 사용) -->
    <hp:run charPrIDRef="7">
      <hp:t>볼드 텍스트</hp:t>
    </hp:run>
    <hp:run charPrIDRef="0">
      <hp:t>를 혼합할 수 있습니다.</hp:t>
    </hp:run>
  </hp:p>

  <!-- ============================================================
       가운데 정렬 문단: paraPrIDRef 변경
       paraPrIDRef="20" → CENTER 정렬 (header.xml에 정의 필요)
       ============================================================ -->
  <hp:p id="1000000005" paraPrIDRef="20" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <hp:run charPrIDRef="7">
      <hp:t>가운데 정렬 + 큰 글씨 제목</hp:t>
    </hp:run>
  </hp:p>

  <!-- ============================================================
       표 (Table)

       구조: hp:tbl > hp:tr > hp:tc > hp:subList > hp:p

       크기 계산:
       - 본문폭: 42520 HWPUNIT (A4 - 좌우여백)
       - 열 너비 합 = 본문폭
       - 예: 3열 균등분배 → 14173 + 14173 + 14174 = 42520

       borderFillIDRef:
       - 3 = 실선 테두리 (데이터 셀)
       - 4 = 실선 테두리 + 배경색 (헤더 셀)
       ============================================================ -->
  <hp:p id="1000000006" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0">
    <hp:run charPrIDRef="0">
      <hp:tbl id="1000000099" zOrder="0" numberingType="TABLE"
              textWrap="TOP_AND_BOTTOM" textFlow="BOTH_SIDES" lock="0"
              dropcapstyle="None" pageBreak="CELL" repeatHeader="0"
              rowCnt="2" colCnt="2" cellSpacing="0" borderFillIDRef="3" noAdjust="0">
        <!-- sz: 표 전체 크기 -->
        <hp:sz width="42520" widthRelTo="ABSOLUTE" height="4800"
               heightRelTo="ABSOLUTE" protect="0"/>
        <!-- pos: treatAsChar="1"이면 글자처럼 취급 -->
        <hp:pos treatAsChar="1" affectLSpacing="0" flowWithText="1" allowOverlap="0"
                holdAnchorAndSO="0" vertRelTo="PARA" horzRelTo="COLUMN"
                vertAlign="TOP" horzAlign="LEFT" vertOffset="0" horzOffset="0"/>
        <hp:outMargin left="0" right="0" top="0" bottom="0"/>
        <hp:inMargin left="0" right="0" top="0" bottom="0"/>

        <!-- 헤더 행: borderFillIDRef="4" (배경색 있음) -->
        <hp:tr>
          <hp:tc name="" header="0" hasMargin="0" protect="0" editable="0" dirty="1"
                 borderFillIDRef="4">
            <hp:subList id="" textDirection="HORIZONTAL" lineWrap="BREAK" vertAlign="CENTER"
                       linkListIDRef="0" linkListNextIDRef="0" textWidth="0" textHeight="0"
                       hasTextRef="0" hasNumRef="0">
              <!-- paraPr 21=가운데/130%, charPr 9=볼드 -->
              <hp:p paraPrIDRef="21" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"
                    id="1000000010">
                <hp:run charPrIDRef="9">
                  <hp:t>항목</hp:t>
                </hp:run>
              </hp:p>
            </hp:subList>
            <hp:cellAddr colAddr="0" rowAddr="0"/>
            <hp:cellSpan colSpan="1" rowSpan="1"/>
            <!-- cellSz: 열 너비, 행 높이 -->
            <hp:cellSz width="21260" height="2400"/>
            <hp:cellMargin left="0" right="0" top="0" bottom="0"/>
          </hp:tc>
          <hp:tc name="" header="0" hasMargin="0" protect="0" editable="0" dirty="1"
                 borderFillIDRef="4">
            <hp:subList id="" textDirection="HORIZONTAL" lineWrap="BREAK" vertAlign="CENTER"
                       linkListIDRef="0" linkListNextIDRef="0" textWidth="0" textHeight="0"
                       hasTextRef="0" hasNumRef="0">
              <hp:p paraPrIDRef="21" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"
                    id="1000000011">
                <hp:run charPrIDRef="9">
                  <hp:t>내용</hp:t>
                </hp:run>
              </hp:p>
            </hp:subList>
            <hp:cellAddr colAddr="1" rowAddr="0"/>
            <hp:cellSpan colSpan="1" rowSpan="1"/>
            <hp:cellSz width="21260" height="2400"/>
            <hp:cellMargin left="0" right="0" top="0" bottom="0"/>
          </hp:tc>
        </hp:tr>

        <!-- 데이터 행: borderFillIDRef="3" (테두리만) -->
        <hp:tr>
          <hp:tc name="" header="0" hasMargin="0" protect="0" editable="0" dirty="1"
                 borderFillIDRef="3">
            <hp:subList id="" textDirection="HORIZONTAL" lineWrap="BREAK" vertAlign="CENTER"
                       linkListIDRef="0" linkListNextIDRef="0" textWidth="0" textHeight="0"
                       hasTextRef="0" hasNumRef="0">
              <!-- paraPr 22=양쪽정렬/130% -->
              <hp:p paraPrIDRef="22" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"
                    id="1000000012">
                <hp:run charPrIDRef="0">
                  <hp:t>데이터 셀</hp:t>
                </hp:run>
              </hp:p>
            </hp:subList>
            <hp:cellAddr colAddr="0" rowAddr="1"/>
            <hp:cellSpan colSpan="1" rowSpan="1"/>
            <hp:cellSz width="21260" height="2400"/>
            <hp:cellMargin left="0" right="0" top="0" bottom="0"/>
          </hp:tc>
          <hp:tc name="" header="0" hasMargin="0" protect="0" editable="0" dirty="1"
                 borderFillIDRef="3">
            <hp:subList id="" textDirection="HORIZONTAL" lineWrap="BREAK" vertAlign="CENTER"
                       linkListIDRef="0" linkListNextIDRef="0" textWidth="0" textHeight="0"
                       hasTextRef="0" hasNumRef="0">
              <hp:p paraPrIDRef="22" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"
                    id="1000000013">
                <hp:run charPrIDRef="0">
                  <hp:t>데이터 값</hp:t>
                </hp:run>
              </hp:p>
            </hp:subList>
            <hp:cellAddr colAddr="1" rowAddr="1"/>
            <hp:cellSpan colSpan="1" rowSpan="1"/>
            <hp:cellSz width="21260" height="2400"/>
            <hp:cellMargin left="0" right="0" top="0" bottom="0"/>
          </hp:tc>
        </hp:tr>
      </hp:tbl>
    </hp:run>
  </hp:p>

</hs:sec>
